# =============================================================================
# Charity Platform — environment template
# Copy:  cp .env.example .env
# Never commit real secrets (.env is gitignored).
# =============================================================================

NODE_ENV=development

# -----------------------------------------------------------------------------
# Gateway (Kong)
# -----------------------------------------------------------------------------
KONG_PROXY_PORT=8000
KONG_ADMIN_PORT=8001

# -----------------------------------------------------------------------------
# Service ports (host / container PORT override)
# -----------------------------------------------------------------------------
IDENTITY_SERVICE_PORT=3001
COMMUNITY_SERVICE_PORT=3002
DONATION_SERVICE_PORT=3003
MARKETPLACE_SERVICE_PORT=3004
COMMUNICATION_SERVICE_PORT=3005
MEDIA_SERVICE_PORT=3006
AI_SERVICE_PORT=3007

# OpenAPI "servers" URL when behind Kong (Swagger Try it out).
# Each Python service has its own default; override only if needed:
#   identity:       OPENAPI_SERVER_URL=/api/identity
#   media:          OPENAPI_SERVER_URL=/api/media
#   communication:  OPENAPI_SERVER_URL=/api/communication

# -----------------------------------------------------------------------------
# Auth (shared JWT — identity signs, other services verify)
# Production: openssl rand -hex 32
# -----------------------------------------------------------------------------
JWT_SECRET=change-me
JWT_ISSUER=charity-auth
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
TWO_FACTOR_CHALLENGE_TTL=5m
TOTP_ISSUER=charity-auth
EMAIL_VERIFICATION_EXPIRY_HOURS=24
PASSWORD_RESET_EXPIRY_HOURS=1

# Deep links in verification / reset emails (frontend)
FRONTEND_BASE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# PostgreSQL (db-per-service; init creates *_db databases)
# Production: strong password; keep POSTGRES_HOST=postgres inside Docker network
# -----------------------------------------------------------------------------
POSTGRES_USER=charity
POSTGRES_PASSWORD=charity
POSTGRES_DB=charity_root
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

IDENTITY_DB_NAME=identity_db
COMMUNITY_DB_NAME=community_db
DONATION_DB_NAME=donation_db
MARKETPLACE_DB_NAME=marketplace_db
COMMUNICATION_DB_NAME=communication_db
MEDIA_DB_NAME=media_db
AI_DB_NAME=ai_db

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# RabbitMQ
# RABBITMQ_URL must use the same user/password as RABBITMQ_USER / RABBITMQ_PASSWORD
# -----------------------------------------------------------------------------
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
RABBITMQ_EXCHANGE=charity.events
COMMUNICATION_EVENTS_QUEUE=communication.events

# -----------------------------------------------------------------------------
# Communication-service — email (Brevo)
# Leave BREVO_API_KEY empty → emails are logged only (dry-run)
# Dashboard: https://app.brevo.com → SMTP & API → API keys
# -----------------------------------------------------------------------------
BREVO_API_KEY=
BREVO_SENDER_EMAIL=noreply@example.com
BREVO_SENDER_NAME=Charity Platform

# -----------------------------------------------------------------------------
# Communication-service — push (Firebase Cloud Messaging)
# Leave empty → push is logged only (dry-run)
# Use a Firebase service account JSON fields:
#   project_id  → FCM_PROJECT_ID
#   client_email → FCM_CLIENT_EMAIL
#   private_key  → FCM_PRIVATE_KEY  (keep \n as literal \n in one line)
# Example:
# FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
# -----------------------------------------------------------------------------
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# Chat (Socket.IO) — no extra secret; uses JWT_SECRET for handshake
# Via Kong:  io(gateway, { path: '/api/communication/socket.io', auth: { token } })
# Direct:    io('http://localhost:3005', { path: '/socket.io', auth: { token } })

# Appointment reminders (communication-service)
REMINDER_LEAD_HOURS=2
REMINDER_INTERVAL_SECONDS=300

# -----------------------------------------------------------------------------
# Media-service — SeaweedFS (self-hosted, S3-compatible)
# Runs in Docker (service name: seaweedfs). See infra/seaweedfs/s3.json.
#
# SEAWEED_S3_ENDPOINT          — media-service → storage (Docker DNS)
# SEAWEED_S3_PUBLIC_ENDPOINT   — host browsers use for presigned PUT
# SEAWEED_PUBLIC_BASE_URL      — public_url = BASE + "/" + object_key
#                                (usually {PUBLIC_ENDPOINT}/{BUCKET})
#
# Ports (host): 8333 S3 · 9333 master · 8888 filer
# Credentials must match infra/seaweedfs/s3.json (defaults below).
# -----------------------------------------------------------------------------
SEAWEED_S3_PORT=8333
SEAWEED_MASTER_PORT=9333
SEAWEED_FILER_PORT=8888
SEAWEED_S3_ENDPOINT=http://seaweedfs:8333
SEAWEED_S3_PUBLIC_ENDPOINT=http://localhost:8333
SEAWEED_ACCESS_KEY_ID=seaweed
SEAWEED_SECRET_ACCESS_KEY=seaweed
SEAWEED_BUCKET=media
SEAWEED_PUBLIC_BASE_URL=http://localhost:8333/media
SEAWEED_S3_REGION=us-east-1

# -----------------------------------------------------------------------------
# AI-service — LLM provider (optional until AI is implemented)
# -----------------------------------------------------------------------------
LLM_PROVIDER=
LLM_API_KEY=
LLM_MODEL=
