{
  "openapi": "3.0.0",
  "info": {
    "title": "Marketplace Service API",
    "version": "1.0.0",
    "description": "API documentation for the Marketplace Service."
  },
  "servers": [
    {
      "url": "/api/marketplace",
      "description": "Kong gateway"
    },
    {
      "url": "http://localhost:3004",
      "description": "Direct (local)"
    }
  ],
  "tags": [
    { "name": "Listings", "description": "Operations about listings" },
    { "name": "Requests", "description": "Operations about item requests" },
    { "name": "Stats", "description": "Marketplace statistics" }
  ],
  "paths": {
    "/catalog": {
      "get": {
        "tags": ["Listings"],
        "summary": "Get catalog of active listings",
        "parameters": [
          { "in": "query", "name": "category", "schema": { "type": "string" } },
          { "in": "query", "name": "province", "schema": { "type": "string" } },
          { "in": "query", "name": "group_id", "schema": { "type": "string" } },
          { "in": "query", "name": "page", "schema": { "type": "integer", "default": 1 } },
          { "in": "query", "name": "limit", "schema": { "type": "integer", "default": 20 } }
        ],
        "responses": {
          "200": { "description": "A list of catalog items" }
        }
      }
    },
    "/listings": {
      "get": {
        "tags": ["Listings"],
        "summary": "Returns a list of listings",
        "parameters": [
          { "in": "query", "name": "status", "schema": { "type": "string" } },
          { "in": "query", "name": "group_id", "schema": { "type": "string" } },
          { "in": "query", "name": "category_id", "schema": { "type": "string" } },
          { "in": "query", "name": "province_code", "schema": { "type": "string" } },
          { "in": "query", "name": "district_code", "schema": { "type": "string" } },
          { "in": "query", "name": "search", "schema": { "type": "string" } },
          { "in": "query", "name": "page", "schema": { "type": "integer", "default": 1 } },
          { "in": "query", "name": "limit", "schema": { "type": "integer", "default": 20 } }
        ],
        "responses": {
          "200": { "description": "A JSON array of listings" }
        }
      },
      "post": {
        "tags": ["Listings"],
        "summary": "Create a new listing",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "inventory_item_id": { "type": "string" },
                  "group_id": { "type": "string" },
                  "title": { "type": "string" },
                  "description": { "type": "string" },
                  "category_id": { "type": "string" },
                  "condition": { "type": "string" },
                  "quantity_total": { "type": "integer" },
                  "created_by": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Listing created successfully" }
        }
      }
    },
    "/listings/{id}": {
      "get": {
        "tags": ["Listings"],
        "summary": "Get listing by ID",
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "A single listing" }
        }
      },
      "put": {
        "tags": ["Listings"],
        "summary": "Update a listing",
        "security": [
          { "bearerAuth": [] }
        ],
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": { "type": "string" },
                  "description": { "type": "string" },
                  "condition": { "type": "string" },
                  "category_id": { "type": "string", "format": "uuid" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Listing updated successfully" }
        }
      }
    },
    "/listings/{id}/close": {
      "put": {
        "tags": ["Listings"],
        "summary": "Close a listing",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": { "user_id": { "type": "string", "format": "uuid" } },
                "required": ["user_id"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Listing closed" }
        }
      }
    },
    "/requests": {
      "get": {
        "tags": ["Requests"],
        "summary": "Get all item requests",
        "parameters": [
          { "in": "query", "name": "group_id", "schema": { "type": "string", "format": "uuid" } },
          { "in": "query", "name": "listing_id", "schema": { "type": "string", "format": "uuid" } },
          { "in": "query", "name": "status", "schema": { "type": "string" } },
          { "in": "query", "name": "receiver_id", "schema": { "type": "string", "format": "uuid" } },
          { "in": "query", "name": "page", "schema": { "type": "integer", "default": 1 } },
          { "in": "query", "name": "limit", "schema": { "type": "integer", "default": 20 } }
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": { "description": "A list of requests" }
        }
      },
      "post": {
        "tags": ["Requests"],
        "summary": "Create an item request",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "listing_id": { "type": "string" },
                  "group_id": { "type": "string" },
                  "receiver_id": { "type": "string" },
                  "quantity": { "type": "integer" },
                  "reason": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Request created successfully" }
        }
      }
    },
    "/requests/{id}/approve": {
      "put": {
        "tags": ["Requests"],
        "summary": "Approve a request",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": { "reviewed_by": { "type": "string", "format": "uuid" } },
                "required": ["reviewed_by"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Request approved" }
        }
      }
    },
    "/requests/{id}/reject": {
      "put": {
        "tags": ["Requests"],
        "summary": "Reject a request",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "reviewed_by": { "type": "string", "format": "uuid" },
                  "reason": { "type": "string" }
                },
                "required": ["reviewed_by", "reason"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Request rejected" }
        }
      }
    },
    "/requests/{id}/schedule": {
      "put": {
        "tags": ["Requests"],
        "summary": "Schedule a request",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "reviewed_by": { "type": "string", "format": "uuid" },
                  "scheduled_at": { "type": "string", "format": "date-time" }
                },
                "required": ["reviewed_by", "scheduled_at"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Request scheduled" }
        }
      }
    },
    "/requests/{id}/complete": {
      "put": {
        "tags": ["Requests"],
        "summary": "Complete a request",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "confirmed_by": { "type": "string" },
                  "qr_token": { "type": "string" },
                  "photo_url": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Request completed" }
        }
      }
    },
    "/requests/{id}/cancel": {
      "put": {
        "tags": ["Requests"],
        "summary": "Cancel a request",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": { "user_id": { "type": "string", "format": "uuid" } },
                "required": ["user_id"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Request cancelled" }
        }
      }
    },
    "/requests/{id}/no_show": {
      "put": {
        "tags": ["Requests"],
        "summary": "Mark a request as no-show",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": { "reviewer_id": { "type": "string", "format": "uuid" } },
                "required": ["reviewer_id"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Request marked as no-show" }
        }
      }
    },
    "/stats/summary": {
      "get": {
        "tags": ["Stats"],
        "summary": "Get aggregate statistics summary",
        "parameters": [
          { "in": "query", "name": "group_id", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Aggregated statistics data" }
        }
      }
    },
    "/stats": {
      "get": {
        "tags": ["Stats"],
        "summary": "Get daily statistics",
        "parameters": [
          { "in": "query", "name": "from_date", "schema": { "type": "string", "format": "date" } },
          { "in": "query", "name": "to_date", "schema": { "type": "string", "format": "date" } },
          { "in": "query", "name": "group_id", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Statistics data" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}
